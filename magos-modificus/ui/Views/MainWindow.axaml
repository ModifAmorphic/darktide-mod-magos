<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Magos.Modificus.UI.ViewModels"
        xmlns:profiles="using:Magos.Modificus.Profiles"
        x:Class="Magos.Modificus.UI.Views.MainWindow"
        x:DataType="vm:ShellViewModel"
        Title="Magos Modificus"
        Width="960" Height="640"
        MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterScreen">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Top bar: app title · profile dropdown · Manage… · Launch Darktide -->
    <Border Grid.Row="0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="0,0,0,1"
            Padding="20,12">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto">

        <!-- App title (left) -->
        <TextBlock Grid.Column="0"
                   Text="Magos Modificus"
                   FontSize="18" FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Margin="0,0,24,0" />

        <!-- Profile controls: dropdown + Manage… (compact, infrequent UX) -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center">
          <ComboBox ItemsSource="{Binding Profiles}"
                    SelectedItem="{Binding SelectedProfile}"
                    IsEnabled="{Binding HasProfiles}"
                    PlaceholderText="No profile"
                    MinWidth="180">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="profiles:ProfileSummary">
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button Content="Manage profiles…"
                  Command="{Binding ManageProfilesCommand}" />
        </StackPanel>

        <!-- Launch Darktide (right) -->
        <Button Grid.Column="3"
                Content="Launch Darktide"
                Command="{Binding LaunchCommand}"
                VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- Main area: the mod list — dominant, full width. Empty state until Track B. -->
    <Panel Grid.Row="1">
      <TextBlock Text="Select or create a profile to manage its mods."
                 IsVisible="{Binding !HasSelectedProfile}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Opacity="0.6" />
    </Panel>

    <!-- Status strip: game-running indicator -->
    <Border Grid.Row="2"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="0,1,0,0"
            Padding="20,6">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <TextBlock Text="●" FontSize="11" VerticalAlignment="Center"
                   Foreground="#22A06B"
                   IsVisible="{Binding IsGameRunning}" />
        <TextBlock Text="●" FontSize="11" VerticalAlignment="Center"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                   IsVisible="{Binding !IsGameRunning}" />
        <TextBlock Text="{Binding GameRunningText}"
                   FontSize="12" Opacity="0.8"
                   VerticalAlignment="Center" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
