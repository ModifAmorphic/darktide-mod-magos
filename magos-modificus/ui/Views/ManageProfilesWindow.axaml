<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Magos.Modificus.UI.ViewModels"
        xmlns:behaviors="using:Magos.Modificus.UI.Behaviors"
        x:Class="Magos.Modificus.UI.Views.ManageProfilesWindow"
        x:DataType="vm:ManageProfilesViewModel"
        Title="Manage profiles"
        Width="520" Height="440"
        MinWidth="440" MinHeight="360"
        CanResize="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

  <Grid x:Name="Root" RowDefinitions="*,Auto" Margin="16">

    <!-- Editable profile list: each row = active marker · name/rename · ✏ · 🗑 -->
    <Border Grid.Row="0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="1"
            CornerRadius="4">
      <ScrollViewer Padding="4">
        <StackPanel>

          <ItemsControl ItemsSource="{Binding Items}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ProfileItemViewModel">
                <Grid ColumnDefinitions="20,*,Auto,Auto" Margin="4,3">

                  <!-- active marker (●) -->
                  <TextBlock Grid.Column="0"
                             Text="●"
                             FontSize="12"
                             Foreground="#22A06B"
                             VerticalAlignment="Center"
                             IsVisible="{Binding IsActive}" />

                  <!-- name (display; hidden while editing) -->
                  <TextBlock Grid.Column="1"
                             Text="{Binding Name}"
                             VerticalAlignment="Center"
                             IsVisible="{Binding !IsEditing}" />

                  <!-- inline rename (shown only while editing) -->
                  <TextBox Grid.Column="1"
                           Text="{Binding EditText, Mode=TwoWay}"
                           IsVisible="{Binding IsEditing}"
                           behaviors:FocusOnVisible.IsEnabled="True"
                           KeyDown="EditBox_KeyDown"
                           LostFocus="EditBox_LostFocus" />

                  <!-- ✏ rename (hidden while editing) -->
                  <Button Grid.Column="2"
                          Content="✏"
                          ToolTip.Tip="Rename"
                          Click="Rename_Click"
                          CommandParameter="{Binding}"
                          MinWidth="36" Margin="6,0,0,0"
                          VerticalAlignment="Center"
                          IsVisible="{Binding !IsEditing}" />

                  <!-- 🗑 delete -->
                  <Button Grid.Column="3"
                          Content="🗑"
                          ToolTip.Tip="Delete"
                          Click="Delete_Click"
                          CommandParameter="{Binding}"
                          MinWidth="36" Margin="6,0,0,0"
                          VerticalAlignment="Center" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- "+ New profile" add row -->
          <Button Content="+ New profile"
                  Command="{Binding StartCreateCommand}"
                  IsVisible="{Binding !IsAddingNew}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left"
                  Margin="4,8,4,3"
                  MinHeight="32" />
          <TextBox Text="{Binding NewProfileName, Mode=TwoWay}"
                   PlaceholderText="New profile name…"
                   IsVisible="{Binding IsAddingNew}"
                   behaviors:FocusOnVisible.IsEnabled="True"
                   KeyDown="AddBox_KeyDown"
                   LostFocus="AddBox_LostFocus"
                   Margin="4,8,4,3" />

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Done -->
    <Button Grid.Row="1"
            Content="Done"
            HorizontalAlignment="Right"
            Click="Done_Click"
            MinWidth="96"
            Margin="0,12,0,0" />
  </Grid>
</Window>
