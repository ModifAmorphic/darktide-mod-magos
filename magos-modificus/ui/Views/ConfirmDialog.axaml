<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Magos.Modificus.UI.Views.ConfirmDialog"
        Title="{ReflectionBinding [Confirm_Title], Source={StaticResource Loc}}"
        Width="420" MinWidth="320"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

  <Border Padding="24">
    <StackPanel Spacing="16">
      <TextBlock x:Name="MessageText"
                 TextWrapping="Wrap" />
      <StackPanel Orientation="Horizontal"
                  Spacing="8"
                  HorizontalAlignment="Right">
        <Button Content="{ReflectionBinding [Confirm_CancelButton], Source={StaticResource Loc}}"
                Click="Cancel_Click"
                MinWidth="80" />
        <Button Content="{ReflectionBinding [Confirm_OkButton], Source={StaticResource Loc}}"
                Name="ConfirmButton"
                Click="Confirm_Click"
                Classes="accent"
                MinWidth="80" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
