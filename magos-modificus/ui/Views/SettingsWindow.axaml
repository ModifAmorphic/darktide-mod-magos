<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Magos.Modificus.UI.ViewModels"
        xmlns:views="using:Magos.Modificus.UI.Views"
        xmlns:settings="using:Magos.Modificus.UI.Settings"
        x:Class="Magos.Modificus.UI.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="{ReflectionBinding [Settings_Title], Source={StaticResource Loc}}"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        Width="560" Height="520"
        MinWidth="480" MinHeight="380"
        CanResize="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

  <!--
    The Settings modal. Custom chrome (DialogTitleBar) mirrors the Track A/D
    modal pattern. Two sections (Discovery + Storage) each a labeled block of
    rows; a Done button closes. Discovery rows are bound to DiscoveryRows
    (an ItemsControl of DiscoveryFieldRowViewModel); the ModsFolder row is
    bespoke (read-only TextBox + Browse). Each row's Browse button is wired
    through the view code-behind (the picker is a view concern).
  -->
  <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
          BorderThickness="1">
    <Grid RowDefinitions="Auto,*,Auto">

      <views:DialogTitleBar Grid.Row="0" />

      <ScrollViewer Grid.Row="1" Padding="24,16" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20">

          <!-- ============== Discovery section ============== -->
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding DiscoverySectionHeader}"
                       FontWeight="SemiBold" />
            <ItemsControl ItemsSource="{Binding DiscoveryRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:DiscoveryFieldRowViewModel">
                  <Grid ColumnDefinitions="160,*,Auto" Margin="0,4">
                    <TextBlock Grid.Column="0"
                               Text="{Binding Label}"
                               VerticalAlignment="Center" />
                     <TextBox Grid.Column="1"
                              Text="{Binding Value, Mode=TwoWay}"
                              Margin="8,0,0,0"
                              VerticalAlignment="Center" />
                    <Button Grid.Column="2"
                            Content="{ReflectionBinding [Discovery_BrowseButton], Source={StaticResource Loc}}"
                            Click="BrowseDiscovery_Click"
                            CommandParameter="{Binding Field.BrowseKind}"
                            MinWidth="80" Margin="8,0,0,0"
                            VerticalAlignment="Center" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <!-- ============== Storage section ============== -->
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding StorageSectionHeader}"
                       FontWeight="SemiBold" />
            <Grid ColumnDefinitions="160,*,Auto" Margin="0,4">
              <TextBlock Grid.Column="0"
                         Text="{Binding ModsFolderLabel}"
                         VerticalAlignment="Center" />
              <TextBox Grid.Column="1"
                       Text="{Binding ModsFolder, Mode=OneWay}"
                       IsReadOnly="True"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center" />
              <Button Grid.Column="2"
                      Content="{ReflectionBinding [Discovery_BrowseButton], Source={StaticResource Loc}}"
                      Click="BrowseModsFolder_Click"
                      MinWidth="80" Margin="8,0,0,0"
                      VerticalAlignment="Center" />
            </Grid>
            <TextBlock Text="{Binding StatusMessage}"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                       FontSize="11"
                       TextWrapping="Wrap" />
          </StackPanel>

        </StackPanel>
      </ScrollViewer>

      <!-- Done -->
      <Button Grid.Row="2"
              Content="{ReflectionBinding [Settings_DoneButton], Source={StaticResource Loc}}"
              Click="Done_Click"
              HorizontalAlignment="Right"
              MinWidth="96"
              Margin="24,12" />
    </Grid>
  </Border>
</Window>
