<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Magos.Modificus.UI.ViewModels"
        xmlns:views="using:Magos.Modificus.UI.Views"
        x:Class="Magos.Modificus.UI.Views.ImportModDialog"
        x:DataType="vm:ImportModViewModel"
        Title="{ReflectionBinding [Import_Title], Source={StaticResource Loc}}"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        Width="480" MinWidth="400"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

  <!--
    The per-mod import modal. Custom chrome (WindowTitleBar) mirrors the Track D
    modal pattern. One is shown per imported path by the add flow; OK collects the
    source + conditional Version + URL (URL parsed to canonical identity), Cancel
    yields null and cancels the batch. SizeToContent="Height" fits the varying
    field count (Local shows nothing extra; Nexus / GitHub show Version + URL).
  -->
  <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
          BorderThickness="1">
    <Grid RowDefinitions="Auto,*">

      <views:DialogTitleBar Grid.Row="0" />

      <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="24,20">
        <StackPanel Grid.Row="0" Spacing="12">

          <!-- Mod name (editable; pre-filled from the folder / archive stem). -->
          <StackPanel Spacing="4">
            <TextBlock Text="{ReflectionBinding [Import_NameLabel], Source={StaticResource Loc}}" />
            <TextBox Text="{Binding ModName, Mode=TwoWay}"
                     PlaceholderText="{ReflectionBinding [Import_NameLabel], Source={StaticResource Loc}}" />
          </StackPanel>

          <!-- Source chooser: Untracked / Nexus / GitHub. -->
          <StackPanel Spacing="4">
            <TextBlock Text="{ReflectionBinding [Import_SourceLabel], Source={StaticResource Loc}}" />
            <ComboBox SelectedIndex="{Binding SourceChoiceIndex, Mode=TwoWay}" MinWidth="160">
              <ComboBoxItem Content="{ReflectionBinding [Import_SourceUntracked], Source={StaticResource Loc}}" />
              <ComboBoxItem Content="{ReflectionBinding [Import_SourceNexus], Source={StaticResource Loc}}" />
              <ComboBoxItem Content="{ReflectionBinding [Import_SourceGitHub], Source={StaticResource Loc}}" />
            </ComboBox>
          </StackPanel>

          <!-- Version (Nexus / GitHub only; required). -->
          <StackPanel Spacing="4" IsVisible="{Binding IsVersionVisible}">
            <TextBlock Text="{ReflectionBinding [Import_VersionLabel], Source={StaticResource Loc}}" />
            <TextBox Text="{Binding Version, Mode=TwoWay}" MinWidth="160" />
            <TextBlock Text="{Binding VersionValidationMessage}"
                       IsVisible="{Binding VersionValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                       FontSize="11" />
          </StackPanel>

          <!-- URL (Nexus / GitHub only; label + placeholder adapt). -->
          <StackPanel Spacing="4" IsVisible="{Binding IsRemote}">
            <TextBlock Text="{Binding UrlLabel}" />
            <TextBox Text="{Binding Url, Mode=TwoWay}"
                     PlaceholderText="{Binding UrlPlaceholder}" />
            <TextBlock Text="{Binding UrlValidationMessage}"
                       IsVisible="{Binding UrlValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                       FontSize="11" />
          </StackPanel>

          <!-- Version policy: Latest (default) or Pinned to this version (remote only). -->
          <StackPanel Spacing="4" IsVisible="{Binding IsVersionVisible}">
            <TextBlock Text="{ReflectionBinding [Import_PolicyLabel], Source={StaticResource Loc}}" />
            <ComboBox SelectedIndex="{Binding PolicyChoiceIndex, Mode=TwoWay}" MinWidth="160">
              <ComboBoxItem Content="{ReflectionBinding [Import_PolicyLatest], Source={StaticResource Loc}}" />
              <ComboBoxItem Content="{ReflectionBinding [Import_PolicyPinned], Source={StaticResource Loc}}" />
            </ComboBox>
          </StackPanel>
        </StackPanel>

        <!-- Buttons. -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
          <Button Content="{ReflectionBinding [Import_CancelButton], Source={StaticResource Loc}}"
                  Click="Cancel_Click"
                  MinWidth="80" />
          <Button Content="{ReflectionBinding [Import_OkButton], Source={StaticResource Loc}}"
                  Name="ConfirmButton"
                  Click="Ok_Click"
                  IsEnabled="{Binding CanConfirm}"
                  Classes="accent"
                  MinWidth="80" />
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
