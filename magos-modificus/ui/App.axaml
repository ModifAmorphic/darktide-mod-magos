<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:Magos.Modificus.UI.Localization"
             x:Class="Magos.Modificus.UI.App"
             RequestedThemeVariant="Default">

    <!--
      Window.FontSize cascades to all child controls via property inheritance, so
      a single Window style applies the global font scale across every window.
      The DynamicResource picks up live changes when AppFontSize is overwritten.
    -->
    <Application.Styles>
        <FluentTheme />
        <Style Selector="Window">
            <Setter Property="FontSize" Value="{DynamicResource AppFontSize}" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <!--
          The LocalizationService is exposed app-wide as a resource so every
          view binds localized strings through one source + one instance:
            <TextBlock Text="{Binding [App_Title], Source={StaticResource Loc}}" />
          The instance is replaced with the real DI singleton at startup (in
          App.OnFrameworkInitializationCompleted), so the XAML-time instance is
          only a design-time placeholder.
        -->
        <loc:LocalizationService x:Key="Loc" />
        <!--
          Base UI font size, in pixels. The PreferencesService applies the user's
          font scale by overwriting this resource; the Window style above binds
          Window.FontSize to it, and child controls inherit. Default = unscaled
          (overwritten at startup from the loaded config).
        -->
        <x:Double x:Key="AppFontSize">14</x:Double>
        <!--
          Status-strip font size, in pixels. Smaller than the body font (the
          status strip is a secondary, low-emphasis line). The PreferencesService
          overwrites it with the same scale as AppFontSize; MainWindow's status
          TextBlock binds FontSize to it. Default = unscaled (overwritten at
          startup from the loaded config).
        -->
        <x:Double x:Key="AppStatusFontSize">12</x:Double>
    </Application.Resources>
</Application>
