# AI Agents temporary directory
.agents


## C++ https://github.com/github/gitignore/blob/main/C%2B%2B.gitignore
# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Linker files
*.ilk

# Debugger Files
*.pdb

# Compiled Dynamic libraries
*.so
*.dylib
*.dll
*.so.*

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# Build directories
build/
Build/
build-*/

# CMake generated files
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
install_manifest.txt
compile_commands.json

# Python
.venv/
__pycache__/

# Temporary files
*.tmp
*.log
*.bak
*.swp

# vcpkg
vcpkg_installed/

# debug information files
*.dwo

# test output & cache
Testing/
.cache/

# Local files
_local/

# Rust / cargo build artifacts
/**/target/
**/*.rs.bk

# Mixed-DLL build outputs (all build outputs land in enginseer/bin/), launch
# batch file. The global *.dll/*.exe/*.lib/*.o ignores already cover the
# contents; the explicit /enginseer/bin/ documents intent.
/enginseer/bin/
/launch.bat
*.obj

# Ignore local mods directory. Used for local testing and validation.
mods/

## .NET / Magos Modificus
**/bin/
**/obj/
*.user
*.suo
*.userprefs
.vs/
TestResults/
