{
  "$schema": "https://json.schemastore.org/json",
  "_comment": "Sample Modificus Curator global config. Copy to <app-data>/config.json and edit. Every field has a default; specify only what you want to override.",
  "Logging": {
    "Level": "Information",
    "LogFile": "<app-data>/logs/curator-{DateTime}.log",
    "RetainedLogFileCount": 5
  },
  "ProfilesBaseFolder": "<app-data>/profiles",
  "ModsFolder": "<app-data>/mods",
  "RelayDir": "<app-data>/relay",
  "Preferences": {
    "Theme": "System",
    "FontScale": 1.0,
    "Language": "en"
  }
}
