<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:Modificus.Curator.UI.Views"
        x:Class="Modificus.Curator.UI.Views.ConfirmDialog"
        Title="{ReflectionBinding [Confirm_Title], Source={StaticResource Loc}}"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        Width="420" MinWidth="320"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

  <!--
    WindowDecorations="None" removes all native chrome (min/max/close); the
    custom title bar (views:DialogTitleBar) provides the drag region + drawn
    close button, and this outer Border re-frames the window. The message is set
    once before the dialog is shown and does not change mid-dialog, so
    SizeToContent="Height" (honored at show time in Avalonia 12.x) sizes the
    window to its content, including the title bar, at the current font scale.
  -->
  <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
          BorderThickness="1">
    <Grid RowDefinitions="Auto,*">

      <views:DialogTitleBar Grid.Row="0" />

      <Border Grid.Row="1" Padding="24">
        <StackPanel Spacing="16">
          <TextBlock x:Name="MessageText"
                     TextWrapping="Wrap" />
          <StackPanel Orientation="Horizontal"
                      Spacing="8"
                      HorizontalAlignment="Right">
            <Button Name="CancelButton"
                    Content="{ReflectionBinding [Confirm_CancelButton], Source={StaticResource Loc}}"
                    Click="Cancel_Click"
                    MinWidth="80" />
            <Button Content="{ReflectionBinding [Confirm_OkButton], Source={StaticResource Loc}}"
                    Name="ConfirmButton"
                    Click="Confirm_Click"
                    Classes="accent"
                    MinWidth="80" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</Window>
