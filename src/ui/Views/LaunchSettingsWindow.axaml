<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Modificus.Curator.UI.ViewModels"
        xmlns:views="using:Modificus.Curator.UI.Views"
        xmlns:behaviors="using:Modificus.Curator.UI.Behaviors"
        x:Class="Modificus.Curator.UI.Views.LaunchSettingsWindow"
        x:DataType="vm:LaunchSettingsViewModel"
        Title="{ReflectionBinding [LaunchSettings_Title], Source={StaticResource Loc}}"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        Width="540" MinWidth="460"
        Height="520" MinHeight="360"
        CanResize="True"
        ShowInTaskbar="False"
        behaviors:EscapeClosesBehavior.IsEnabled="True"
        WindowStartupLocation="CenterOwner">

  <!--
    Custom chrome (WindowTitleBar) mirrors the other Curator modals. Two scrollable
    sections (env-var rows + game-arg rows, each add/remove) with inline localized validation,
    a static next-launch hint, and Save / Cancel. Resizable so the user can grow it for long
    lists; SizeToContent is avoided so a long list does not push the buttons off-screen.
  -->
  <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
          BorderThickness="1">
    <Grid RowDefinitions="Auto,*">

      <views:DialogTitleBar Grid.Row="0" />

      <Grid Grid.Row="1" RowDefinitions="*,Auto" Margin="16">
        <ScrollViewer Grid.Row="0" Padding="4">
          <StackPanel Spacing="16">

            <!-- Environment variables section -->
            <StackPanel Spacing="6">
              <TextBlock Text="{ReflectionBinding [LaunchSettings_EnvHeader], Source={StaticResource Loc}}"
                       FontWeight="SemiBold" />
              <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                      BorderThickness="1"
                      CornerRadius="4">
                <StackPanel Spacing="2" Margin="6">
                  <ItemsControl ItemsSource="{Binding EnvironmentVariables}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:EnvVarRow">
                        <StackPanel Spacing="2" Margin="0,2">
                          <Grid ColumnDefinitions="*,*,Auto" Margin="0,2">
                            <TextBox Grid.Column="0"
                                     Text="{Binding Name, Mode=TwoWay}"
                                     PlaceholderText="{ReflectionBinding [LaunchSettings_EnvNamePlaceholder], Source={StaticResource Loc}}"
                                     MinWidth="120" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Value, Mode=TwoWay}"
                                     PlaceholderText="{ReflectionBinding [LaunchSettings_EnvValuePlaceholder], Source={StaticResource Loc}}" />
                            <Button Grid.Column="2"
                                    ToolTip.Tip="{ReflectionBinding [LaunchSettings_RemoveTooltip], Source={StaticResource Loc}}"
                                    Click="RemoveEnv_Click"
                                    CommandParameter="{Binding}"
                                    MinWidth="36" Margin="6,0,0,0"
                                    VerticalAlignment="Center">
                              <!-- Material "close" cross (24x24 source): drawn geometry,
                                   inherits the button foreground. -->
                              <Path Width="14" Height="14" Stretch="Uniform"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Fill="{Binding $parent[Button].Foreground}"
                                    Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                            </Button>
                          </Grid>
                          <TextBlock Text="{Binding ErrorMessage}"
                                     IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                     Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                                     FontSize="11"
                                     Margin="0,2" />
                        </StackPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <Button Content="{ReflectionBinding [LaunchSettings_AddEnvVar], Source={StaticResource Loc}}"
                          Command="{Binding AddEnvVarCommand}"
                          HorizontalAlignment="Left"
                          Margin="0,2"
                          MinHeight="32" />
                </StackPanel>
              </Border>
            </StackPanel>

            <!-- Game arguments section -->
            <StackPanel Spacing="6">
              <TextBlock Text="{ReflectionBinding [LaunchSettings_GameArgsHeader], Source={StaticResource Loc}}"
                       FontWeight="SemiBold" />
              <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                      BorderThickness="1"
                      CornerRadius="4">
                <StackPanel Spacing="2" Margin="6">
                  <ItemsControl ItemsSource="{Binding GameArguments}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:GameArgRow">
                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                          <TextBox Grid.Column="0"
                                   Text="{Binding Value, Mode=TwoWay}"
                                   PlaceholderText="{ReflectionBinding [LaunchSettings_GameArgPlaceholder], Source={StaticResource Loc}}" />
                          <Button Grid.Column="1"
                                  ToolTip.Tip="{ReflectionBinding [LaunchSettings_RemoveTooltip], Source={StaticResource Loc}}"
                                  Click="RemoveArg_Click"
                                  CommandParameter="{Binding}"
                                  MinWidth="36" Margin="6,0,0,0"
                                  VerticalAlignment="Center">
                            <!-- Material "close" cross: drawn geometry, inherits foreground. -->
                            <Path Width="14" Height="14" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Fill="{Binding $parent[Button].Foreground}"
                                  Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                          </Button>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <Button Content="{ReflectionBinding [LaunchSettings_AddGameArg], Source={StaticResource Loc}}"
                          Command="{Binding AddGameArgCommand}"
                          HorizontalAlignment="Left"
                          Margin="0,2"
                          MinHeight="32" />
                </StackPanel>
              </Border>
            </StackPanel>

            <!-- Static next-launch hint. -->
            <TextBlock Text="{ReflectionBinding [LaunchSettings_NextLaunchHint], Source={StaticResource Loc}}"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11" />

          </StackPanel>
        </ScrollViewer>

        <!-- Buttons. A top-level save error is shown above the row, when present. -->
        <StackPanel Grid.Row="1" Spacing="8" Margin="0,12,0,0">
          <TextBlock Text="{Binding SaveError}"
                   IsVisible="{Binding SaveError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                   FontSize="11" />
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="{ReflectionBinding [LaunchSettings_CancelButton], Source={StaticResource Loc}}"
                    Click="Cancel_Click"
                    MinWidth="80" />
            <Button Content="{ReflectionBinding [LaunchSettings_SaveButton], Source={StaticResource Loc}}"
                    Name="SaveButton"
                    Click="Save_Click"
                    IsEnabled="{Binding CanSave}"
                    Classes="accent"
                    MinWidth="80" />
          </StackPanel>
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
