<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Modificus.Curator.UI.ViewModels"
        xmlns:views="using:Modificus.Curator.UI.Views"
        xmlns:settings="using:Modificus.Curator.UI.Settings"
        xmlns:behaviors="using:Modificus.Curator.UI.Behaviors"
        x:Class="Modificus.Curator.UI.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="{ReflectionBinding [Settings_Title], Source={StaticResource Loc}}"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        Width="560" Height="600"
        MinWidth="480" MinHeight="460"
        CanResize="True"
        ShowInTaskbar="False"
        behaviors:EscapeClosesBehavior.IsEnabled="True"
        WindowStartupLocation="CenterOwner">

  <!--
    The Settings modal. Custom chrome (DialogTitleBar) mirrors the Track A/D
    modal pattern. Two sections (Discovery + Storage) each a labeled block of
    rows; a Done button closes. Discovery rows are bound to DiscoveryRows
    (an ItemsControl of DiscoveryFieldRowViewModel); the ModsFolder row is
    bespoke (read-only TextBox + Browse). Each row's Browse button is wired
    through the view code-behind (the picker is a view concern).
  -->
  <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
          BorderThickness="1">
    <Grid RowDefinitions="Auto,*,Auto">

      <views:DialogTitleBar Grid.Row="0" />

      <StackPanel Grid.Row="1" Spacing="20" Margin="24,16">

          <!-- ============== Discovery section ============== -->
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding DiscoverySectionHeader}"
                       FontWeight="SemiBold" />
            <ItemsControl ItemsSource="{Binding DiscoveryRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:DiscoveryFieldRowViewModel">
                  <Grid ColumnDefinitions="160,*,Auto" Margin="0,4">
                    <TextBlock Grid.Column="0"
                               Text="{Binding Label}"
                               VerticalAlignment="Center" />
                     <TextBox Grid.Column="1"
                              Text="{Binding Value, Mode=TwoWay}"
                              Margin="8,0,0,0"
                              VerticalAlignment="Center" />
                    <Button Grid.Column="2"
                            Content="{ReflectionBinding [Discovery_BrowseButton], Source={StaticResource Loc}}"
                            Click="BrowseDiscovery_Click"
                            CommandParameter="{Binding Field.BrowseKind}"
                            MinWidth="80" Margin="8,0,0,0"
                            VerticalAlignment="Center" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <!-- ============== Storage section ============== -->
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding StorageSectionHeader}"
                       FontWeight="SemiBold" />
            <Grid ColumnDefinitions="160,*,Auto" Margin="0,4">
              <TextBlock Grid.Column="0"
                         Text="{Binding ModsFolderLabel}"
                         VerticalAlignment="Center" />
              <TextBox Grid.Column="1"
                       Text="{Binding ModsFolder, Mode=OneWay}"
                       IsReadOnly="True"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center" />
              <Button Grid.Column="2"
                      Content="{ReflectionBinding [Discovery_BrowseButton], Source={StaticResource Loc}}"
                      Click="BrowseModsFolder_Click"
                      MinWidth="80" Margin="8,0,0,0"
                      VerticalAlignment="Center" />
            </Grid>
            <TextBlock Text="{Binding StatusMessage}"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                       FontSize="11"
                       TextWrapping="Wrap" />
          </StackPanel>

          <!-- ============== Updates section ============== -->
          <!--
            Always shown (current version + Check for Updates), so Linux / dev
            builds (IsUpdateSupported=false) still see the version with a disabled
            Check button. The Check button's enabled state follows its command's
            CanExecute (gated on IsAppUpdateSupported && !IsCheckingAppUpdate);
            an indeterminate spinner replaces the press affordance while a check
            runs. The Download and Restart button is visible only when an update
            is available.
          -->
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding UpdatesSectionHeader}"
                       FontWeight="SemiBold" />
            <Grid ColumnDefinitions="160,*" Margin="0,4">
              <TextBlock Grid.Column="0"
                         Text="{Binding CurrentVersionLabel}"
                         VerticalAlignment="Center" />
              <TextBlock Grid.Column="1"
                         Text="{Binding CurrentVersionDisplay}"
                         Margin="8,0,0,0"
                         VerticalAlignment="Center" />
            </Grid>
            <CheckBox IsChecked="{Binding CheckOnStartup, Mode=TwoWay}"
                      Content="{ReflectionBinding [Settings_CheckOnStartup], Source={StaticResource Loc}}"
                      ToolTip.Tip="{ReflectionBinding [Settings_CheckOnStartupTooltip], Source={StaticResource Loc}}"
                      Margin="0,4" />
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4">
              <Button Content="{ReflectionBinding [Settings_CheckForUpdatesButton], Source={StaticResource Loc}}"
                      Command="{Binding CheckAppUpdateCommand}"
                      VerticalAlignment="Center" />
              <ProgressBar Width="18" Height="18"
                           IsIndeterminate="True"
                           IsVisible="{Binding IsCheckingAppUpdate}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4">
              <TextBlock Text="{Binding AppUpdateStatusMessage}"
                         IsVisible="{Binding AppUpdateStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                         VerticalAlignment="Center"
                         TextWrapping="Wrap" />
              <Button Content="{ReflectionBinding [Settings_DownloadAndRestartButton], Source={StaticResource Loc}}"
                      Command="{Binding DownloadAndRestartAppUpdateCommand}"
                      IsVisible="{Binding IsAppUpdateAvailable}"
                      VerticalAlignment="Center" />
            </StackPanel>
          </StackPanel>

      </StackPanel>

      <!-- Done -->
      <Button Grid.Row="2"
              Content="{ReflectionBinding [Settings_DoneButton], Source={StaticResource Loc}}"
              Click="Done_Click"
              HorizontalAlignment="Right"
              MinWidth="96"
              Margin="24,12" />
    </Grid>
  </Border>
</Window>
