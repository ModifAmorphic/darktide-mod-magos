<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Modificus.Curator.UI.ViewModels"
        xmlns:views="using:Modificus.Curator.UI.Views"
        x:Class="Modificus.Curator.UI.Views.PreferencesWindow"
        x:DataType="vm:PreferencesViewModel"
        Title="{ReflectionBinding [Preferences_Title], Source={StaticResource Loc}}"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        Width="440"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

  <!--
    WindowDecorations="None" removes all native chrome (min/max/close), so a
    custom title bar (views:DialogTitleBar) provides the drag region + drawn
    close button, and this outer Border re-frames the window (the native border
    is gone). Height is not set: the dialog auto-fits its content (see the
    code-behind), which keeps "Done" on-screen as the font-scale slider grows it.
  -->
  <Border x:Name="ContentRoot"
          BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
          BorderThickness="1">
    <Grid RowDefinitions="Auto,*">

      <views:DialogTitleBar Grid.Row="0" />

      <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto" Margin="20">

        <!-- Theme picker -->
        <Grid Grid.Row="0"
              RowDefinitions="Auto,Auto"
              Margin="0,0,0,12">
          <TextBlock Grid.Row="0"
                     Text="{ReflectionBinding [Preferences_ThemeHeader], Source={StaticResource Loc}}"
                     FontWeight="SemiBold"
                     Margin="0,0,0,6" />
          <ComboBox Grid.Row="1"
                    ItemsSource="{Binding ThemeOptions}"
                    SelectedItem="{Binding SelectedTheme}"
                    MinWidth="200"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:ThemeOption">
                <TextBlock Text="{Binding Label}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </Grid>

        <!-- Font scale slider -->
        <Grid Grid.Row="1"
              RowDefinitions="Auto,Auto,Auto"
              Margin="0,0,0,12">
          <Grid Grid.Row="0"
                ColumnDefinitions="*,Auto"
                Margin="0,0,0,6">
            <TextBlock Grid.Column="0"
                       Text="{ReflectionBinding [Preferences_FontScaleHeader], Source={StaticResource Loc}}"
                       FontWeight="SemiBold" />
            <TextBlock Grid.Column="1"
                       Text="{Binding FontScalePercent, StringFormat='{}{0}%'}"
                       VerticalAlignment="Center" />
          </Grid>
          <Slider Grid.Row="1"
                  Minimum="80"
                  Maximum="150"
                  Value="{Binding FontScalePercent}"
                  TickFrequency="5"
                  IsSnapToTickEnabled="True"
                  MinWidth="240" />
          <StackPanel Grid.Row="2"
                      Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Spacing="0">
            <TextBlock Text="80%  "
                       FontSize="11" Opacity="0.6" />
            <TextBlock Text="150%"
                       FontSize="11" Opacity="0.6" />
          </StackPanel>
        </Grid>

        <!-- Language picker -->
        <Grid Grid.Row="2"
              RowDefinitions="Auto,Auto"
              Margin="0,0,0,12">
          <TextBlock Grid.Row="0"
                     Text="{ReflectionBinding [Preferences_LanguageHeader], Source={StaticResource Loc}}"
                     FontWeight="SemiBold"
                     Margin="0,0,0,6" />
          <ComboBox Grid.Row="1"
                    ItemsSource="{Binding LanguageOptions}"
                    SelectedItem="{Binding SelectedLanguage}"
                    MinWidth="200"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:LanguageOption">
                <TextBlock Text="{Binding Label}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </Grid>

        <!-- Done -->
        <Button Grid.Row="3"
                Content="{ReflectionBinding [Preferences_DoneButton], Source={StaticResource Loc}}"
                HorizontalAlignment="Right"
                Click="Done_Click"
                MinWidth="96"
                Margin="0,8,0,0" />
      </Grid>
    </Grid>
  </Border>
</Window>
