<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Modificus.Curator.UI.ViewModels"
        xmlns:views="using:Modificus.Curator.UI.Views"
        xmlns:behaviors="using:Modificus.Curator.UI.Behaviors"
        x:Class="Modificus.Curator.UI.Views.ManageProfilesWindow"
        x:DataType="vm:ManageProfilesViewModel"
        Title="{ReflectionBinding [ManageProfiles_Title], Source={StaticResource Loc}}"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        Width="520" Height="480"
        MinWidth="440" MinHeight="360"
        CanResize="True"
        ShowInTaskbar="False"
        behaviors:EscapeClosesBehavior.IsEnabled="True"
        WindowStartupLocation="CenterOwner">

  <!--
    WindowDecorations="None" removes all native chrome (min/max/close); the
    custom title bar (views:DialogTitleBar) provides the drag region + drawn
    close button, and this outer Border re-frames the window. Content is static
    over the dialog's lifetime (the list is scrollable), so no live-fit is needed:
    the fixed size accommodates the title bar at the current font scale.
  -->
  <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
          BorderThickness="1">
    <Grid RowDefinitions="Auto,*">

      <views:DialogTitleBar Grid.Row="0" />

      <Grid Grid.Row="1" x:Name="Root" RowDefinitions="*,Auto" Margin="16">

    <!-- Editable profile list: each row = active marker · name/rename · pencil · trash -->
    <Border Grid.Row="0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="1"
            CornerRadius="4">
      <ScrollViewer Padding="4">
        <StackPanel>

          <ItemsControl ItemsSource="{Binding Items}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ProfileItemViewModel">
                <Grid ColumnDefinitions="20,*,Auto,Auto,Auto" Margin="4,3">

                  <!-- active marker (drawn Ellipse, no glyph) -->
                  <Ellipse Grid.Column="0"
                           Width="9" Height="9"
                           Fill="#22A06B"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsActive}" />

                  <!-- name (display; hidden while editing) -->
                  <TextBlock Grid.Column="1"
                             Text="{Binding Name}"
                             VerticalAlignment="Center"
                             IsVisible="{Binding !IsEditing}" />

                  <!-- inline rename (shown only while editing) -->
                  <TextBox Grid.Column="1"
                           Text="{Binding EditText, Mode=TwoWay}"
                           IsVisible="{Binding IsEditing}"
                           behaviors:FocusOnVisible.IsEnabled="True"
                           KeyDown="EditBox_KeyDown"
                           LostFocus="EditBox_LostFocus" />

                  <!-- pencil rename (hidden while editing) -->
                  <Button Grid.Column="2"
                          ToolTip.Tip="{ReflectionBinding [ManageProfiles_RenameTooltip], Source={StaticResource Loc}}"
                          Click="Rename_Click"
                          CommandParameter="{Binding}"
                          MinWidth="36" Margin="6,0,0,0"
                          VerticalAlignment="Center"
                          IsVisible="{Binding !IsEditing}">
                    <!-- Material "create" pencil (24x24 source): drawn geometry,
                         so it renders identically everywhere and inherits the
                         button foreground (theme + pressed states). -->
                    <Path Width="16" Height="16" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Fill="{Binding $parent[Button].Foreground}"
                          Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34a.9959.9959 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" />
                  </Button>

                  <!-- launch settings (tune): opens the per-profile launch-settings modal -->
                  <Button Grid.Column="3"
                          ToolTip.Tip="{ReflectionBinding [ManageProfiles_LaunchSettingsTooltip], Source={StaticResource Loc}}"
                          Click="LaunchSettings_Click"
                          CommandParameter="{Binding}"
                          MinWidth="36" Margin="6,0,0,0"
                          VerticalAlignment="Center"
                          IsVisible="{Binding !IsEditing}">
                    <!-- Material "tune" icon (24x24 source): drawn geometry,
                         inherits the button foreground. -->
                    <Path Width="16" Height="16" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Fill="{Binding $parent[Button].Foreground}"
                          Data="M3 17v2h6v-2H3zM3 5v2h10V5H3zm10 16v-2h8v-2h-8v-2h-2v6h2zM7 9v2H3v2h4v2h2V9H7zm14 4v-2H11v2h10zm-6-4h2V7h4V5h-4V3h-2v6z" />
                  </Button>

                  <!-- trash delete (disabled on the active row while Darktide runs) -->
                  <Button Grid.Column="4"
                          ToolTip.Tip="{Binding DeleteTooltip}"
                          IsEnabled="{Binding IsDeleteEnabled}"
                          Click="Delete_Click"
                          CommandParameter="{Binding}"
                          MinWidth="36" Margin="6,0,0,0"
                          VerticalAlignment="Center">
                    <!-- Material "delete" trash can (24x24 source): drawn
                         geometry, inherits the button foreground. -->
                    <Path Width="16" Height="16" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Fill="{Binding $parent[Button].Foreground}"
                          Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" />
                  </Button>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- "+ New profile" add row -->
          <Button Content="{ReflectionBinding [ManageProfiles_NewButton], Source={StaticResource Loc}}"
                  Command="{Binding StartCreateCommand}"
                  IsVisible="{Binding !IsAddingNew}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left"
                  Margin="4,8,4,3"
                  MinHeight="32" />
          <TextBox Text="{Binding NewProfileName, Mode=TwoWay}"
                   PlaceholderText="{ReflectionBinding [ManageProfiles_NewPlaceholder], Source={StaticResource Loc}}"
                   IsVisible="{Binding IsAddingNew}"
                   behaviors:FocusOnVisible.IsEnabled="True"
                   KeyDown="AddBox_KeyDown"
                   LostFocus="AddBox_LostFocus"
                   Margin="4,8,4,3" />

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Done -->
    <Button Grid.Row="1"
            Content="{ReflectionBinding [ManageProfiles_DoneButton], Source={StaticResource Loc}}"
            HorizontalAlignment="Right"
            Click="Done_Click"
            MinWidth="96"
            Margin="0,12,0,0" />
      </Grid>
    </Grid>
  </Border>
</Window>
