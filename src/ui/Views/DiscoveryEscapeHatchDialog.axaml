<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Modificus.Curator.UI.ViewModels"
        xmlns:views="using:Modificus.Curator.UI.Views"
        xmlns:behaviors="using:Modificus.Curator.UI.Behaviors"
        x:Class="Modificus.Curator.UI.Views.DiscoveryEscapeHatchDialog"
        x:DataType="vm:DiscoveryEscapeHatchViewModel"
        Title="{ReflectionBinding [EscapeHatch_Title], Source={StaticResource Loc}}"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        Width="520" MinWidth="440"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        behaviors:EscapeClosesBehavior.IsEnabled="True"
        WindowStartupLocation="CenterOwner">

  <!--
    The discovery escape-hatch modal. Custom chrome (DialogTitleBar) mirrors the
    Track A/D modal pattern. A friendly header (NOT framed as an error: discovery
    is incomplete, the user is being asked to help), then one row per missing
    field (label + TextBox + Browse), then the retry hint + Submit/Cancel buttons.
    SizeToContent="Height" fits the varying row count (Windows has 2 missing
    fields at most; Linux can have all 4).
  -->
  <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
          BorderThickness="1">
    <Grid RowDefinitions="Auto,*">

      <views:DialogTitleBar Grid.Row="0" />

      <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto" Margin="24,16">
        <StackPanel Grid.Row="0" Spacing="12">
          <TextBlock Text="{Binding Header}"
                     TextWrapping="Wrap"
                     FontWeight="SemiBold" />

          <ItemsControl ItemsSource="{Binding Rows}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:DiscoveryFieldRowViewModel">
                <Grid ColumnDefinitions="140,*,Auto" Margin="0,4">
                  <TextBlock Grid.Column="0"
                             Text="{Binding Label}"
                             VerticalAlignment="Center" />
                  <TextBox Grid.Column="1"
                           Text="{Binding Value, Mode=TwoWay}"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center" />
                  <Button Grid.Column="2"
                          Content="{ReflectionBinding [Discovery_BrowseButton], Source={StaticResource Loc}}"
                          Click="Browse_Click"
                          CommandParameter="{Binding Field.BrowseKind}"
                          MinWidth="80" Margin="8,0,0,0"
                          VerticalAlignment="Center" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Text="{Binding RetryHint}"
                     Opacity="0.8"
                     TextWrapping="Wrap" />
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
          <Button Content="{ReflectionBinding [EscapeHatch_CancelButton], Source={StaticResource Loc}}"
                  Click="Cancel_Click"
                  MinWidth="80" />
          <Button Content="{ReflectionBinding [EscapeHatch_SubmitButton], Source={StaticResource Loc}}"
                  Click="Submit_Click"
                  Classes="accent"
                  MinWidth="80" />
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
