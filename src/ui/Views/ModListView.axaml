<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Modificus.Curator.UI.ViewModels"
             x:Class="Modificus.Curator.UI.Views.ModListView"
             x:DataType="vm:ModListViewModel">

  <UserControl.Styles>
    <!-- Source badge: a subtle pill so it reads as metadata, not body text.
         Applies to the HyperlinkButton variant too (the badge is a link). -->
    <Style Selector="Border.badge">
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="6,1" />
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <!-- The source badge as a clickable link: pill styling carries over from
         Border.badge, plus a transparent background + a pointer-cursor so the
         badge reads as a link when its SourceUrl is set. The HyperlinkButton's
         default theme is a hyperlink (underline, accent color); this override
         restores the pill look. -->
    <Style Selector="HyperlinkButton.badge">
      <Setter Property="Padding" Value="6,1" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <!-- Compact icon buttons (up / down / trash / update): flat, inherit foreground. -->
    <Style Selector="Button.icon">
      <Setter Property="Padding" Value="6" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <!--
      The stable Nexus Latest update-action button carries the "updateAction"
      class IN ADDITION to "icon" so a disabled style can be scoped to it alone.
      The button stays visible when no update is available (it is logically
      disabled via UpdateActionEnabled); without this override the inherited
      disabled foreground reads too close to the enabled icon buttons in Fluent.
      The :disabled pseudo-class dims the whole button to 0.4 opacity, so the
      no-update state is unmistakably subdued/grey. Scoped to updateAction only:
      the move/remove icon buttons (which never take this class) are unaffected,
      and the accent-blue ENABLED state is untouched (:disabled is inactive then).
    -->
    <Style Selector="Button.updateAction:disabled">
      <Setter Property="Opacity" Value="0.4" />
    </Style>
  </UserControl.Styles>

  <!--
    The active profile's mod list: header (title + rate-limit notice +
    check-now refresh + auto-sort + Add split button) over a
    scrollable row list, with owned empty states (no profile / no mods). The
    whole content area is a drag-and-drop target (folders + archives), so mods can
    be added by dropping as well as via the Add split button's archive + folder
    pickers. Drag-and-drop is a Windows-only feature in Avalonia 12.0.x (XDND
    lands in 12.1), surfaced via a hint in the no-mods empty state + the
    content-area tooltip; the folder picker covers folder import on all
    platforms. Row interactions route through code-behind handlers to the
    parent VM's commands (the established ManageProfilesWindow pattern),
    passing the row as CommandParameter.

    Icons + markers are drawn <Path> geometry (Material 24x24 source) and
    Ellipse, never Unicode glyphs, per AGENTS.md. The SplitButton's arrow is
    built-in theme chrome, not an authored glyph.
  -->

  <Grid RowDefinitions="Auto,*" Margin="20,12,20,12">

    <!-- Header: title + rate-limit notice + check-now refresh + auto-sort
         toggle + Add split button (hidden until a profile is active). The title
         reads the plain "Mods" label (no count; the row list itself is the
         count). -->
    <Grid Grid.Row="0"
          ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto"
          IsVisible="{Binding HasActiveProfile}"
          Margin="0,0,0,8">
      <!-- Title: the plain localized "Mods" label (no count; the row list itself
           is the count). Bound to HeaderCountText so it live-refreshes on a
           culture change (the VM re-fires the property). Sits in column 0,
           immediately before the rate-limit notice + the refresh button. -->
      <TextBlock Grid.Column="0"
                 Text="{Binding HeaderCountText}"
                 FontSize="16" FontWeight="SemiBold"
                 VerticalAlignment="Center" />
      <Border Grid.Column="1"
              Classes="rateLimitedNotice"
              IsVisible="{Binding IsRateLimited}"
              Background="{DynamicResource SystemControlBackgroundCautionBrush}"
              CornerRadius="8"
              Padding="6,1"
              Margin="8,0,0,0"
              VerticalAlignment="Center"
              ToolTip.Tip="{ReflectionBinding [ModList_RateLimitedTooltip], Source={StaticResource Loc}}">
        <StackPanel Orientation="Horizontal" Spacing="4">
          <Ellipse Width="6" Height="6"
                   Fill="{DynamicResource SystemControlForegroundCautionBrush}"
                   VerticalAlignment="Center" />
          <TextBlock Text="{Binding RateLimitedNoticeText}"
                     FontSize="11" VerticalAlignment="Center" />
        </StackPanel>
      </Border>
      <!--
        Manual "check for updates now": a refresh-affordance button (drawn
        refresh-arrow Path, no glyph), always visible (independent of the
        periodic-check toggle). Click routes through code-behind to the VM's
        CheckForUpdatesNow command, which fires an immediate THOROUGH check
        (the per-mod pass that also catches mods outside the Month window) +
        drives the IsCheckingNow affordance while it runs. The result lands via
        the existing CheckCompleted subscription. The button stays visible at
        all times; it disables while a thorough check is in flight
        (IsCheckingNow) OR while the manual sliding-window throttle is active
        (IsRefreshEnabled covers both), and an indeterminate progress spinner
        overlays the refresh icon for the duration. The tooltip is the VM's
        ManualRefreshTooltip: the normal "check for updates now" string
        normally, or the live m:ss countdown ("Rate limiting protection
        enabled. Manual refresh will be available again in {time}.") while
        throttled.
      -->
      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                  Margin="8,0,0,0" VerticalAlignment="Center">
        <Button Classes="icon"
                Click="RefreshUpdates_Click"
                IsEnabled="{Binding IsRefreshEnabled}"
                VerticalAlignment="Center"
                ToolTip.Tip="{Binding ManualRefreshTooltip}">
          <!-- Material "refresh" (24x24 source): drawn geometry, themed via the
               button foreground. -->
          <Path Width="16" Height="16" Stretch="Uniform"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Fill="{Binding $parent[Button].Foreground}"
                Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" />
        </Button>
        <!-- Indeterminate progress while the thorough check runs (multiple API
             calls, a few seconds). Sits beside the (visible but disabled)
             refresh button; IsVisible=False collapses it out of layout when no
             check is running so the button stands alone. -->
        <ProgressBar Width="18" Height="18"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsCheckingNow}"
                     VerticalAlignment="Center" />
      </StackPanel>
      <!--
        Auto-sort toggle. Intentionally hidden (IsVisible="False"): the real
        dependency-driven IModOrderResolver lands later. The wiring (the
        AutoSortEnabled binding, the AutoSort_Click handler, the
        IdentityModOrderResolver registration) stays intact so the seam drops in
        without a UI change; only the control is collapsed out of layout.
      -->
      <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="16,0,0,0"
                  IsVisible="False">
        <CheckBox IsChecked="{Binding AutoSortEnabled, Mode=TwoWay}"
                  Click="AutoSort_Click"
                  ToolTip.Tip="{ReflectionBinding [ModList_AutoSortTooltip], Source={StaticResource Loc}}" />
        <TextBlock Text="{ReflectionBinding [ModList_AutoSort], Source={StaticResource Loc}}"
                   VerticalAlignment="Center" />
      </StackPanel>
      <!--
        Add split button: primary click opens the current mode's picker (archive file
        picker by default, folder picker after the folder flyout item is chosen);
        the arrow opens the flyout to switch modes. The TextBlock binds to the
        VM's AddModeLabel so it reads "Add Mod (archive)" / "Add Mod (folder)". The
        arrow is built-in theme chrome (no authored glyph). Folders need a picker
        path because drag-and-drop is a Windows-only feature in Avalonia 12.0.x.
      -->
      <SplitButton Grid.Column="5"
                   Click="Add_Click"
                   ToolTip.Tip="{ReflectionBinding [ModList_AddButtonTooltip], Source={StaticResource Loc}}"
                   Margin="16,0,0,0"
                   VerticalAlignment="Center">
        <SplitButton.Content>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <!-- Material "add" plus (24x24 source): drawn geometry. -->
            <Path Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"
                  Fill="{Binding $parent[SplitButton].Foreground}"
                  Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
            <TextBlock Text="{Binding AddModeLabel}" VerticalAlignment="Center" />
          </StackPanel>
        </SplitButton.Content>
        <SplitButton.Flyout>
          <MenuFlyout>
            <MenuItem Header="{ReflectionBinding [ModList_AddArchive], Source={StaticResource Loc}}"
                      Click="AddArchive_Click" />
            <MenuItem Header="{ReflectionBinding [ModList_AddFolder], Source={StaticResource Loc}}"
                      Click="AddFolder_Click" />
          </MenuFlyout>
        </SplitButton.Flyout>
      </SplitButton>
    </Grid>

    <!--
      Content area: the drag-and-drop target (AllowDrop/Drop/DragOver stay here
      so drag-and-drop behavior is unchanged). The drag-hint tooltip is NOT
      attached here: this Grid is the ancestor of populated mod rows, so a
      tooltip on it would surface while hovering rows. The tooltip is scoped to
      the no-mods empty state below, where the hint is actually relevant.
      Empty states + the row list overlap; visibility selects which shows.
    -->
    <Grid Grid.Row="1"
          DragDrop.AllowDrop="True"
          DragDrop.Drop="OnDrop"
          DragDrop.DragOver="OnDragOver">

      <!-- Empty: no active profile. -->
      <TextBlock Text="{Binding EmptyNoProfileText}"
                 IsVisible="{Binding !HasActiveProfile}"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Opacity="0.6" />

      <!--
        Empty: active profile but no mods yet. The drag-and-drop hint sits below
        the message as a small, low-opacity secondary cue, AND the same hint is
        attached as this container's tooltip (scoped here, not on the content
        Grid, so it does not appear while hovering populated rows). The no-profile
        state does not carry the hint. (Drag-and-drop is a Windows-only feature;
        the folder picker covers Linux.)
      -->
      <StackPanel IsVisible="{Binding IsEmptyNoMods}"
                  HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                  ToolTip.Tip="{ReflectionBinding [ModList_DragDropHint], Source={StaticResource Loc}}">
        <TextBlock Text="{Binding EmptyNoModsText}"
                   HorizontalAlignment="Center"
                   Opacity="0.6" />
        <TextBlock Text="{ReflectionBinding [ModList_DragDropHint], Source={StaticResource Loc}}"
                   FontSize="11"
                   Opacity="0.6"
                   HorizontalAlignment="Center" />
      </StackPanel>

      <!-- The mod rows (visible only when there is at least one mod). -->
      <Border IsVisible="{Binding HasMods}"
              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
              BorderThickness="1"
              CornerRadius="4">
        <ScrollViewer Padding="2">
          <ItemsControl ItemsSource="{Binding Mods}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ModItemViewModel">
                <!--
                  Row layout (8 columns): Name | source badge + update marker |
                  enabled | policy editor | update button / progress | up | down |
                  remove. The Update button + the indeterminate ProgressBar share
                  column 4 (toggled by IsUpdating); they sit between the policy
                  editor and the list-management cluster so they group with
                  per-mod actions rather than list reordering.
                -->
                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      Margin="6,3" MinHeight="32">

                  <!-- Name -->
                  <TextBlock Grid.Column="0"
                             Text="{Binding Name}"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis" />

                  <!--
                    Source badge area. The indeterminate progress affordance (shown
                    only while this row's IsUpdating is true) sits immediately LEFT
                    of the source-badge HyperlinkButton, occupying the former
                    update-status area, so the row's update activity is visible
                    without replacing the stable update-action button in column 4.
                    The badge is a HyperlinkButton styled as the pill; its
                    NavigateUri is the row's SourceUrl (null for Untracked, which
                    the HyperlinkButton treats as a no-op click).
                  -->
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                              Margin="8,0,0,0" VerticalAlignment="Center">
                    <!-- Indeterminate progress while a per-row update install
                         runs. Visible only for the row whose IsUpdating is true.
                         Placed left of the badge (where the old update-available
                         marker used to begin). -->
                    <ProgressBar Width="18" Height="18"
                                 IsIndeterminate="True"
                                 IsVisible="{Binding IsUpdating}"
                                 VerticalAlignment="Center" />
                    <HyperlinkButton Classes="badge"
                                     NavigateUri="{Binding SourceUrl}"
                                     ToolTip.Tip="{ReflectionBinding [ModRow_SourceBadgeLinkTooltip], Source={StaticResource Loc}}">
                      <TextBlock Text="{Binding SourceBadgeText}" FontSize="11" />
                    </HyperlinkButton>
                  </StackPanel>

                  <!-- Enabled toggle (two-way; Click applies via the parent). -->
                  <CheckBox Grid.Column="2"
                            IsChecked="{Binding Enabled, Mode=TwoWay}"
                            Click="Enabled_Click"
                            ToolTip.Tip="{ReflectionBinding [ModRow_EnabledTooltip], Source={StaticResource Loc}}"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center" />

                  <!-- Policy editor: ComboBox (Latest/Pinned) + inline version dropdown. -->
                  <!--
                    The pin is a constrained dropdown of the container's versions
                    (bound to the row's AvailableVersions): the user can only pin to
                    a version that exists in the container. The dropdown shows the
                    readable version tag and stores the opaque folder id, which the
                    parent's SetPolicyPinned command wraps as PinnedPolicy(versionId).
                    (The import-modal version field stays free-text: it declares the
                    version of files being imported, which is how a new version row
                    enters the container in the first place.)
                  -->
                  <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6"
                              Margin="12,0,0,0" VerticalAlignment="Center">
                    <ComboBox SelectedIndex="{Binding PolicyChoice, Mode=TwoWay}"
                              SelectionChanged="Policy_Changed"
                              MinWidth="100">
                      <ComboBoxItem Content="{ReflectionBinding [ModRow_PolicyLatest], Source={StaticResource Loc}}" />
                      <ComboBoxItem Content="{ReflectionBinding [ModRow_PolicyPinned], Source={StaticResource Loc}}" />
                    </ComboBox>
                    <ComboBox ItemsSource="{Binding AvailableVersions}"
                              SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                              SelectionChanged="PinnedVersion_Changed"
                              IsVisible="{Binding IsPinned}"
                              PlaceholderText="{ReflectionBinding [ModRow_PinnedVersionPlaceholder], Source={StaticResource Loc}}"
                              MinWidth="120">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:VersionOption">
                          <TextBlock Text="{Binding VersionString}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>

                  <!--
                    The stable update-action cell. A fixed-width Panel reserves
                    space on EVERY row (so later controls never shift when the
                    button appears/disappears). For Nexus + Latest rows it holds
                    the update button; for Pinned Nexus and Untracked
                    rows the cell stays reserved but empty. The button stays
                    visible even while a row is updating (it is disabled via
                    UpdateActionEnabled); the indeterminate progress affordance
                    moved to the source-badge area (column 1) so the action cell
                    does not shift during start/end of an update.

                    The button shows for Nexus + Latest rows regardless of
                    account tier + regardless of whether an update is available.
                    No update -> disabled, neutral/grey download arrow (inherits
                    the disabled foreground + the updateAction :disabled style
                    dims the whole button to 0.4 opacity so it is unmistakably
                    subdued). Update available -> enabled, with the drawn
                    download-arrow Path in accent blue. No animation/flashing, no
                    Unicode icons. Premium click runs the existing in-app update;
                    regular/unknown click opens the mod's Nexus files page (the
                    row VM carries the click behavior; the tooltip distinguishes
                    the cases).
                  -->
                  <Panel Grid.Column="4" Margin="8,0,0,0" VerticalAlignment="Center"
                         MinWidth="28">
                    <Button Classes="icon updateAction"
                            Click="Update_Click"
                            CommandParameter="{Binding}"
                            IsVisible="{Binding CanShowUpdateAction}"
                            IsEnabled="{Binding UpdateActionEnabled}"
                            ToolTip.Tip="{Binding UpdateActionTooltip}">
                      <Panel>
                        <!-- Neutral/grey download arrow (no update / disabled):
                             inherits the button foreground; the updateAction
                             :disabled style further dims the whole button to
                             0.4 opacity so the no-update state is unmistakably
                             subdued. -->
                        <Path Width="16" Height="16" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              IsVisible="{Binding !UpdateAvailable}"
                              Fill="{Binding $parent[Button].Foreground}"
                              Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" />
                        <!-- Accent-blue download arrow (update available). -->
                        <Path Width="16" Height="16" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              IsVisible="{Binding UpdateAvailable}"
                              Fill="{DynamicResource SystemControlForegroundAccentBrush}"
                              Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" />
                      </Panel>
                    </Button>
                  </Panel>

                  <!-- Move up (drawn up-chevron). -->
                  <Button Grid.Column="5" Classes="icon"
                          ToolTip.Tip="{ReflectionBinding [ModRow_MoveUpTooltip], Source={StaticResource Loc}}"
                          Click="MoveUp_Click"
                          CommandParameter="{Binding}"
                          Margin="8,0,0,0">
                    <Path Width="16" Height="16" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Fill="{Binding $parent[Button].Foreground}"
                          Data="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z" />
                  </Button>

                  <!-- Move down (drawn down-chevron). -->
                  <Button Grid.Column="6" Classes="icon"
                          ToolTip.Tip="{ReflectionBinding [ModRow_MoveDownTooltip], Source={StaticResource Loc}}"
                          Click="MoveDown_Click"
                          CommandParameter="{Binding}"
                          Margin="4,0,0,0">
                    <Path Width="16" Height="16" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Fill="{Binding $parent[Button].Foreground}"
                          Data="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z" />
                  </Button>

                  <!-- Remove (drawn trash). -->
                  <Button Grid.Column="7" Classes="icon"
                          ToolTip.Tip="{ReflectionBinding [ModRow_RemoveTooltip], Source={StaticResource Loc}}"
                          Click="Remove_Click"
                          CommandParameter="{Binding}"
                          Margin="4,0,0,0">
                    <Path Width="16" Height="16" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Fill="{Binding $parent[Button].Foreground}"
                          Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" />
                  </Button>

                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</UserControl>
