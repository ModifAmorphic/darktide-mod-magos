<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Modificus.Curator.UI.ViewModels"
        xmlns:views="using:Modificus.Curator.UI.Views"
        xmlns:profiles="using:Modificus.Curator.Profiles"
        x:Class="Modificus.Curator.UI.Views.MainWindow"
        x:DataType="vm:ShellViewModel"
        Title="{ReflectionBinding [App_Title], Source={StaticResource Loc}}"
        Icon="/Assets/app-icon.png"
        Width="960" Height="640"
        MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterScreen">

  <Window.Styles>
    <!-- Compact icon button (the dismiss affordance on the update pill): flat,
         inherits the button foreground. Mirrors ModListView's Button.icon. -->
    <Style Selector="Button.icon">
      <Setter Property="Padding" Value="4" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Top bar: app title · profile dropdown · Manage… · Integrations… · Preferences… · Settings · Launch Darktide -->
    <Border Grid.Row="0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="0,0,0,1"
            Padding="20,12">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto">

        <!-- App title (left) -->
        <TextBlock Grid.Column="0"
                   Text="{ReflectionBinding [Shell_ProfileLabel], Source={StaticResource Loc}}"
                   FontSize="18" FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Margin="0,0,24,0" />

        <!-- Profile controls: dropdown + Manage… (compact, infrequent UX) -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center">
          <ComboBox ItemsSource="{Binding Profiles}"
                    SelectedItem="{Binding SelectedProfile}"
                    IsEnabled="{Binding CanSwitchProfile}"
                    ToolTip.Tip="{Binding ProfileSwitchTooltip}"
                    PlaceholderText="{ReflectionBinding [Profile_DropdownPlaceholder], Source={StaticResource Loc}}"
                    MinWidth="180">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="profiles:ProfileSummary">
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button Command="{Binding ManageProfilesCommand}"
                  ToolTip.Tip="{ReflectionBinding [ManageProfiles_ButtonTooltip], Source={StaticResource Loc}}"
                  MinWidth="36">
            <!--
              Material "layers" (24x24 source). Pulled from the canonical
              Google Fonts Material Icons SVG
              (https://fonts.gstatic.com/s/i/materialicons/layers/v1/24px.svg),
              the authoritative source materialicons.github.io points at.
              Chosen for Manage Profiles: stacked layers = multiple mod
              profiles for one user (the "people" alternative was rejected as
              it implies a personal/account profile). Replaces the gear that
              moved to the new Settings button.
            -->
            <Path Width="16" Height="16" Stretch="Uniform"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  Fill="{Binding $parent[Button].Foreground}"
                  Data="M11.99 18.54l-7.37-5.73L3 14.07l9 7 9-7-1.63-1.27-7.38 5.74zM12 16l7.36-5.73L21 9l-9-7-9 7 1.63 1.27L12 16z" />
          </Button>
        </StackPanel>

        <!-- Integrations… (Nexus auth; left, after profiles) -->
        <Button Grid.Column="2"
                Command="{Binding OpenIntegrationsCommand}"
                ToolTip.Tip="{ReflectionBinding [Integrations_ButtonTooltip], Source={StaticResource Loc}}"
                MinWidth="36"
                VerticalAlignment="Center"
                Margin="8,0,0,0">
          <!-- Material "extension" puzzle-piece icon (24x24 source): drawn
               geometry, inherits the button foreground. Chosen for Integrations:
               the canonical "plug things in" symbol (Nexus is the only
               integration in v1; a future GitHub UI etc. would slot in here). -->
          <Path Width="16" Height="16" Stretch="Uniform"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Fill="{Binding $parent[Button].Foreground}"
                Data="M20.5 11H19V7c0-1.1-.9-2-2-2h-4V3.5C13 2.12 11.88 1 10.5 1S8 2.12 8 3.5V5H4c-1.1 0-1.99.9-1.99 2v3.8H3.5c1.49 0 2.7 1.21 2.7 2.7s-1.21 2.7-2.7 2.7H2V20c0 1.1.9 2 2 2h3.8v-1.5c0-1.49 1.21-2.7 2.7-2.7s2.7 1.21 2.7 2.7V22H17c1.1 0 2-.9 2-2v-4h1.5c1.38 0 2.5-1.12 2.5-2.5S21.88 11 20.5 11z" />
        </Button>

        <!-- Preferences… (right, next to Settings + Launch) -->
        <Button Grid.Column="4"
                Command="{Binding OpenPreferencesCommand}"
                ToolTip.Tip="{ReflectionBinding [Preferences_ButtonTooltip], Source={StaticResource Loc}}"
                MinWidth="36"
                VerticalAlignment="Center"
                Margin="0,0,8,0">
          <!-- Material "tune"/"sliders" icon (24x24 source): drawn geometry,
               inherits the button foreground. Chosen to distinguish Preferences
               (sliders) from the gear (Settings) and the layers (profiles)
               next to it. -->
          <Path Width="16" Height="16" Stretch="Uniform"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Fill="{Binding $parent[Button].Foreground}"
                Data="M3 17v2h6v-2H3zM3 5v2h10V5H3zm10 16v-2h8v-2h-8v-2h-2v6h2zM7 9v2H3v2h4v2h2V9H7zm14 4v-2H11v2h10zm-6-4h2V7h4V5h-4V3h-2v6z" />
        </Button>

        <!-- Settings (gear; moved here from Manage Profiles) -->
        <Button Grid.Column="5"
                Command="{Binding OpenSettingsCommand}"
                ToolTip.Tip="{ReflectionBinding [Settings_ButtonTooltip], Source={StaticResource Loc}}"
                MinWidth="36"
                VerticalAlignment="Center"
                Margin="0,0,8,0">
          <!-- Material "settings" gear (24x24 source): drawn geometry, so it
               renders identically everywhere and inherits the button foreground
               (theme + pressed states). The same gear Manage Profiles used to
               carry; moved here so Manage Profiles could take the "layers"
               icon. -->
          <Path Width="16" Height="16" Stretch="Uniform"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Fill="{Binding $parent[Button].Foreground}"
                Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.488.488 0 0 0-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54a.484.484 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94 0 .31.02.64.07.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.21.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" />
        </Button>

        <!-- Launch Darktide (right) -->
        <Button Grid.Column="6"
                Content="{ReflectionBinding [Launch_Button], Source={StaticResource Loc}}"
                Command="{Binding LaunchCommand}"
                VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- Main area: the active profile's mod list (Track B). The view owns all
         content-area empty states (no active profile / no mods); the shell no
         longer carries an inline empty-state message. DataContext bound to the
         shell's ModList VM so the view's x:DataType resolves. -->
    <views:ModListView Grid.Row="1" DataContext="{Binding ModList}" />

    <!-- Status strip: game-running indicator + the transient launch-status note
         + the nxm handler status (enabled / disabled / unavailable). -->
    <Border Grid.Row="2"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="0,1,0,0"
            Padding="20,6">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <Ellipse Width="11" Height="11" VerticalAlignment="Center"
                 Fill="#22A06B"
                 IsVisible="{Binding IsGameRunning}" />
        <Ellipse Width="11" Height="11" VerticalAlignment="Center"
                 Fill="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                 IsVisible="{Binding !IsGameRunning}" />
        <TextBlock Text="{Binding GameRunningText}"
                   FontSize="{DynamicResource AppStatusFontSize}" Opacity="0.8"
                   VerticalAlignment="Center" />
        <TextBlock Text="{Binding LaunchStatusNote}"
                   FontSize="{DynamicResource AppStatusFontSize}" Opacity="0.8"
                   VerticalAlignment="Center"
                   Margin="12,0,0,0"
                   IsVisible="{Binding LaunchStatusNote, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <!-- nxm handler indicator: green when Curator is the registered handler
             (IsNxmEnabled), grey otherwise (covers not registered + no platform
             registrar). Mirrors the game-running Ellipse pair directly above. -->
        <Ellipse Width="11" Height="11" VerticalAlignment="Center"
                 Margin="12,0,0,0"
                 Fill="#22A06B"
                 IsVisible="{Binding IsNxmEnabled}" />
        <Ellipse Width="11" Height="11" VerticalAlignment="Center"
                 Margin="12,0,0,0"
                 Fill="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                 IsVisible="{Binding !IsNxmEnabled}" />
        <TextBlock Text="{Binding NxmHandlerStatusText}"
                   FontSize="{DynamicResource AppStatusFontSize}" Opacity="0.8"
                   VerticalAlignment="Center"
                   ToolTip.Tip="{Binding NxmHandlerStatusTooltip}" />
        <!--
          App self-update notice: a dismissible pill in the status strip. Shown
          only when an update is available (ShowAppUpdateNotice) and not yet
          dismissed this session. The accent dot + the link read as "Curator X
          is available"; clicking the link confirms + downloads + restarts. The
          close button (a drawn Material "close" Path, not a glyph) hides the
          notice for this session. Mirrors the ModListView notice-pill styling
          (Border + Ellipse + content). All icons are drawn geometry per
          AGENTS.md.
        -->
        <Border IsVisible="{Binding ShowAppUpdateNotice}"
                Background="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}"
                CornerRadius="8"
                Padding="6,1"
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                ToolTip.Tip="{Binding AppUpdateNoticeTooltip}">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Ellipse Width="7" Height="7"
                     Fill="{DynamicResource SystemControlForegroundAccentBrush}"
                     VerticalAlignment="Center" />
            <HyperlinkButton Command="{Binding CheckAppUpdateNowCommand}"
                             Padding="2,0" Margin="0" MinWidth="0"
                             VerticalAlignment="Center"
                             ToolTip.Tip="{Binding AppUpdateNoticeTooltip}">
              <TextBlock Text="{Binding AppUpdateNoticeText}"
                         FontSize="{DynamicResource AppStatusFontSize}"
                         VerticalAlignment="Center" />
            </HyperlinkButton>
            <Button Classes="icon"
                    Command="{Binding DismissAppUpdateCommand}"
                    VerticalAlignment="Center"
                    ToolTip.Tip="{Binding AppUpdateDismissTooltip}">
              <!-- Material "close" (24x24 source): drawn geometry, themed via the
                   button foreground. Mirrors the DialogTitleBar close Path. -->
              <Path Width="10" Height="10" Stretch="Uniform"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Fill="{Binding $parent[Button].Foreground}"
                    Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
            </Button>
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>
  </Grid>
</Window>
