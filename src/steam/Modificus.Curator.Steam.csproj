<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Modificus.Curator.Steam</RootNamespace>
    <AssemblyName>Modificus.Curator.Steam</AssemblyName>
  </PropertyGroup>

  <!--
    Exposes internal helpers (the VDF parser) to the test assembly so the parser
    can be unit-tested in isolation without widening the library's public surface.
    Implementation services (SteamService, SteamRegistryReader,
    WinProcessLookup/LinuxProcessLookup) stay internal and are exercised through
    ISteamService via DI in tests.
  -->
  <ItemGroup>
    <InternalsVisibleTo Include="Modificus.Curator.Steam.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.9" />
    <!--
      No Microsoft.Win32.Registry package: on net10.0 the Registry type is in the
      reference assembly, gated behind [SupportedOSPlatform("windows")] (runtime
      throws on non-Windows). SteamRegistryReader is annotated
      [SupportedOSPlatform("windows")] (declares Windows-only at the type level
      for CA1416, no per-call guard) and is registered ONLY on Windows by
      AddSteam(); on Linux it is intentionally absent so resolving
      ISteamRegistryReader fails fast. No new NuGet dependency required.
    -->
  </ItemGroup>

  <ItemGroup>
    <!--
      DiscoveryConfig is the user-override section of CuratorConfig overlaid onto
      the discoverer's result; IConfigLoader (General) is the live reader the
      SteamService reads the Discovery section from on each Discover() call.
    -->
    <ProjectReference Include="..\config\Modificus.Curator.Config.csproj" />
    <ProjectReference Include="..\general\Modificus.Curator.General.csproj" />
  </ItemGroup>

</Project>
